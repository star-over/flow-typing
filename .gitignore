# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

/tmp
/dist

# auto-flow: тексты-источники и сгенерированный корпус (большие, регенерируемые)
/auto-flow/corpus/*
!/auto-flow/corpus/.gitkeep
!/auto-flow/corpus/en/RESEARCH.md
# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# sveltekit
/.svelte-kit/
/build/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

*storybook.log
storybook-static
.storybook-temp/

.gemini/
.claude/settings.local.json
.claude/settings.json
.claude/skills/
gha-creds-*.json

# AI-обвязка инструментов (один скилл impeccable, продублированный под разные
# CLI) — локальная разработческая обвязка, не часть продукта
.agents/
.codex/
.kiro/
.opencode/
# impeccable: версионируем только sidecar design.json (часть дизайн-системы,
# см. CLAUDE.md); локальный конфиг, кэш хука и live-артефакты — мимо
.impeccable/*
!.impeccable/design.json

# git worktrees
.worktrees/
