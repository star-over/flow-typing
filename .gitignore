# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

/tmp
/dist

# auto-flow: тексты-источники и сгенерированный корпус (большие, регенерируемые)
/auto-flow/data/*
!/auto-flow/data/.gitkeep
# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# sveltekit
/.svelte-kit/
/build/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

*storybook.log
storybook-static
.storybook-temp/

.gemini/
.claude/settings.local.json
gha-creds-*.json

# git worktrees
.worktrees/
