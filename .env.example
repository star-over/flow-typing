# Convex cloud dev deployment.
# Run `npx convex dev` to populate .env.local with actual values.
# Format: dev:<deployment-name> for dev tier; URLs follow <deployment-name>.<region>.convex.{cloud,site}.
CONVEX_DEPLOYMENT=
PUBLIC_CONVEX_URL=
# PUBLIC_CONVEX_SITE_URL: сейчас НЕ читается ни одним модулем (grep пуст) — issuer
# берёт CONVEX_SITE_URL на бэкенде авто. Держим как задел Phase 2; при отсутствии
# потребителя — кандидат на удаление.
PUBLIC_CONVEX_SITE_URL=

# Контакт для обратной связи (P0-7): Telegram/email/форма. Задан → в футере
# лендинга появляется тихая feedback-ссылка (LandingScreen.svelte); не задан →
# ссылки нет. Клиентская PUBLIC_*-переменная, запекается в build на этапе vite
# build. Для prod-ссылки задать в сборочном окружении (см. docs/deploy/prod-bootstrap.md).
# PUBLIC_FEEDBACK_URL=https://t.me/your_handle

# Dev-вход для ИИ-агентов и E2E (ADR 0012; механизм — ADR 0024). В .env.local
# задавать НЕ нужно: кнопка dev-входа на /signin живёт за import.meta.env.DEV
# (есть под `make dev`, вырезается из любой `vite build` — CI/prod её не содержит),
# учётка dev-фикстуры зашита в компонент. Серверная половина — Password-провайдер
# за единственным fail-closed гейтом (ADR 0023): dev-deployment должен нести
# `npx convex env set DEPLOY_ENV development`, иначе dev-вход и dev-мутации
# (resetMyProfile / setMyLadderStep) на нём считаются prod и выключены.

# --- Production / CI (P0-2) ---
# Этот файл — только про локальный dev. На prod ничего из .env.local не едет:
#  • CI (.github/workflows/deploy.yml) собирает статику через `convex deploy --cmd`,
#    который сам подставляет prod PUBLIC_CONVEX_URL (--cmd-url-env-var-name). Больше
#    ни одной обязательной PUBLIC_*-переменной сборке не нужно; опциональная
#    PUBLIC_FEEDBACK_URL — задать в сборочном окружении, если нужна feedback-ссылка.
#  • Секреты (CONVEX_DEPLOY_KEY, CLOUDFLARE_API_TOKEN, CLOUDFLARE_ACCOUNT_ID) живут
#    в GitHub Secrets, НЕ здесь.
#  • Prod-env Convex (SITE_URL, JWT_PRIVATE_KEY, JWKS, AUTH_*), fail-closed
#    инверсия (DEPLOY_ENV не ставить) и заливка корпуса —
#    пошагово в docs/deploy/prod-bootstrap.md.
